# 阿里云百炼 API Key
DASHSCOPE_API_KEY=your_api_key_here

# 飞书机器人 Webhook URL
FEISHU_WEBHOOK_URL=

# 钉钉机器人 Webhook URL（可选）
DINGTALK_WEBHOOK_URL=

# ArXiv 检索分类（逗号分隔）
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.CV

# 论文关键词过滤（逗号分隔，留空则不过滤）
KEYWORDS=agent,RAG,alignment,RLHF,reasoning

# 每日抓取时间（24小时制）
SCHEDULE_TIME=09:00

# 每次最大处理论文数
MAX_PAPERS=10

# 日志级别
LOG_LEVEL=INFO
